# ElizaBAO Polymarket Agent - Environment Variables
# Copy this file to .env and fill in your values

# ============================================================
# REQUIRED - AI Provider
# ============================================================
ANTHROPIC_API_KEY=sk-ant-...         # Your Anthropic API key for Claude

# ============================================================
# REQUIRED - Polymarket Wallet
# ============================================================
EVM_PRIVATE_KEY=0x...                # Your wallet private key (Polygon)
WALLET_ADDRESS=0x...                 # Your wallet address

# ============================================================
# REQUIRED FOR TRADING - Polymarket CLOB API
# ============================================================
# Get these from https://polymarket.com after using the platform
CLOB_API_KEY=...
CLOB_API_SECRET=...
CLOB_API_PASSPHRASE=...

# ============================================================
# OPTIONAL - Proxy Wallet (for advanced users)
# ============================================================
PROXY_WALLET=0x...                   # Proxy wallet address if using one

# ============================================================
# OPTIONAL - API URLs (defaults shown)
# ============================================================
GAMMA_API_URL=https://gamma-api.polymarket.com
CLOB_API_URL=https://clob.polymarket.com
XTRACKER_API_URL=https://xtracker.polymarket.com/api

# ============================================================
# OPTIONAL - Server Configuration
# ============================================================
PORT=3001

# ============================================================
# OPTIONAL - HTTP Proxy (to bypass Cloudflare blocks)
# ============================================================
HTTP_PROXY_HOST=45.145.18.24          # Proxy server IP
HTTP_PROXY_PORT=6815                   # Proxy server port
HTTP_PROXY_USER=username               # Proxy username
HTTP_PROXY_PASS=password               # Proxy password

# ============================================================
# OPTIONAL - News Intelligence APIs (for smarter trading)
# ============================================================
# Get free keys from:
# - NewsAPI: https://newsapi.org (100 requests/day free)
# - Brave Search: https://brave.com/search/api (2000/month free)
# - CryptoCompare: https://cryptocompare.com (100k/month free)
# - Alpha Vantage: https://alphavantage.co (25/day free)

NEWSAPI_KEY=                          # NewsAPI.org key
BRAVE_API_KEY=                        # Brave Search API key
CRYPTOCOMPARE_KEY=                    # CryptoCompare key (optional, works without)
ALPHAVANTAGE_KEY=                     # Alpha Vantage key

# ============================================================
# OPTIONAL - ElizaOS Settings
# ============================================================
# OPENAI_API_KEY=sk-...              # Alternative to Anthropic
# PGLITE_DATA_DIR=memory://          # Database directory
